<Window x:Class="Gemelo.Applications.Tournify.Clock.VoiceSelectionWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="KI Stimme auswählen"
        Width="600" Height="640"
        WindowStartupLocation="CenterOwner"
        FontSize="16">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0"
                   x:Name="m_TxtInfo"
                   TextWrapping="Wrap"
                   Margin="0,0,0,10"
                   Text="Verfügbare deutsche Stimmen werden geladen …" />

        <ListBox Grid.Row="1"
                 x:Name="m_ListVoices"
                 DisplayMemberPath="Display"
                 SelectedValuePath="ShortName"
                 SelectionChanged="ListVoices_SelectionChanged"
                 MouseDoubleClick="ListVoices_MouseDoubleClick" />

        <StackPanel Grid.Row="2" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,14,0,0">
            <TextBlock Text="Geschwindigkeit:" VerticalAlignment="Center" Width="140" />
            <Slider x:Name="m_SliderRate"
                    Width="320"
                    VerticalAlignment="Center"
                    Minimum="-20"
                    Maximum="10"
                    TickFrequency="5"
                    SmallChange="5"
                    LargeChange="10"
                    IsSnapToTickEnabled="True"
                    TickPlacement="BottomRight"
                    ValueChanged="SliderRate_ValueChanged" />
            <TextBlock x:Name="m_TxtRate"
                       VerticalAlignment="Center"
                       Width="70"
                       TextAlignment="Right"
                       Text="0%" />
        </StackPanel>

        <StackPanel Grid.Row="3" Orientation="Horizontal" Margin="0,12,0,0">
            <TextBox x:Name="m_TxtTest"
                     Width="380"
                     VerticalContentAlignment="Center"
                     Padding="4"
                     Text="Gleich spielen die Mannschaften || die roten Falken gegen die blauen Drachen || auf dem grünen Platz." />
            <Button x:Name="m_BtnTest"
                    Content="▶ Testen"
                    Margin="10,0,0,0"
                    Padding="14,6"
                    Click="BtnTest_Click" />
        </StackPanel>

        <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
            <Button x:Name="m_BtnOk"
                    Content="Übernehmen"
                    Padding="18,6"
                    IsDefault="True"
                    Click="BtnOk_Click" />
            <Button Content="Abbrechen"
                    Padding="18,6"
                    Margin="10,0,0,0"
                    IsCancel="True"
                    Click="BtnCancel_Click" />
        </StackPanel>
    </Grid>
</Window>
